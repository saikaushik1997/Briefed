# LLM Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# LangSmith tracing
LANGSMITH_API_KEY=
LANGSMITH_TRACING_V2=true
LANGSMITH_PROJECT=Briefed

# Database — matches docker-compose for local dev
DATABASE_URL=postgresql+asyncpg://briefed:briefed@localhost:5432/briefed

# Redis — matches docker-compose for local dev
REDIS_URL=redis://localhost:6379

# MLflow — matches docker-compose for local dev
MLFLOW_TRACKING_URI=http://localhost:5050

# Cloudflare R2 — leave empty to use local file storage in dev
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_ENDPOINT=

ENVIRONMENT=development
